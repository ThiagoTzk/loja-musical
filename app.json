{
  "expo": {
    "name": "loja-musical",
    "slug": "loja-musical",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/blacktone-logo.png",
    "scheme": "lojamusical",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Permitir acesso à câmera para foto de perfil"
      }
    },
    "android": {
      "permissions": [
        "CAMERA"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#0B0F14",
        "foregroundImage": "./assets/images/blacktone-logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Permitir acesso à câmera para tirar foto de perfil"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/blacktone-logo.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#0B0F14",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "44d3865b-0948-400a-ba5d-38ec68510c09"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/44d3865b-0948-400a-ba5d-38ec68510c09"
    }
  }
}
