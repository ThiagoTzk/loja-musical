rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.admin == true;
    }

    function isSafeUserCreate(userId) {
      return isOwner(userId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.admin == false;
    }

    function isSafeUserUpdate(userId) {
      return isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "atualizadoEm",
          "cartaoPadrao",
          "cpf",
          "dataNascimento",
          "enderecoPadrao",
          "fotoURL",
          "nome",
          "perfilCompleto",
          "telefone",
          "ultimoLoginEm"
        ])
        && request.resource.data.admin == resource.data.admin
        && request.resource.data.email == resource.data.email
        && request.resource.data.uid == resource.data.uid;
    }

    match /produtos/{produtoId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /pedidos/{pedidoId} {
      // O pedido e criado pelo SERVIDOR (endpoint POST /api/orders do admin),
      // que recalcula o total a partir dos precos reais e grava via Admin SDK
      // (bypass das rules). Por isso o cliente nao cria pedido direto.
      allow create: if false;

      allow get, list: if isAdmin()
        || (signedIn() && resource.data.usuarioId == request.auth.uid);

      allow update, delete: if isAdmin();
    }

    match /usuarios/{userId} {
      allow create: if isSafeUserCreate(userId);

      allow get: if isOwner(userId) || isAdmin();

      allow list: if isAdmin();

      allow update: if isAdmin() || isSafeUserUpdate(userId);

      allow delete: if false;
    }
  }
}
